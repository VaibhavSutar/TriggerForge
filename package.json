{
  "name": "triggerforge",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "workspaces": [
    "apps/*",
    "packages/*",
    "database",
    "infra"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "generate": "prisma generate --schema=../../database/prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "6.18.0",
    "turbo": "latest",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@prisma/client": "6.18.0"
  }
}