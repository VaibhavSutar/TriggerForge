{
  "name": "@triggerforge/desktop",
  "version": "1.0.0",
  "description": "TriggerForge Desktop App - Automate your workflows natively.",
  "author": "Vaibhav Sutar",
  "repository": "https://github.com/VaibhavSutar/TriggerForge",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "com.triggerforge.app",
    "productName": "TriggerForge",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "next-app"
      },
      {
        "from": "../server/dist",
        "to": "server-app"
      },
      {
        "from": "../../database/prisma",
        "to": "prisma-schema"
      }
    ]
  }
}